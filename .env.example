# ---- Firebase client (public, safe to expose in the browser) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Server-only secrets ----
# Gemini / LLM extraction is CURRENTLY DISABLED (kill-switch in lib/extract.ts).
# The app builds and the aggregator runs (JSON-LD only) with NO Gemini key.
# To re-enable: set GEMINI_ENABLED=true and provide GEMINI_API_KEY below.
GEMINI_ENABLED=false
# Gemini API key (Google AI / Generative Language API) — only needed when enabled.
GEMINI_API_KEY=
# Path to the scraper service-account JSON (local dev). In CI/App Hosting use
# FIREBASE_SERVICE_ACCOUNT (the JSON contents) instead.
GOOGLE_APPLICATION_CREDENTIALS=./.secrets/scraper-sa.json
FIREBASE_SERVICE_ACCOUNT=
GCP_PROJECT_ID=
GEMINI_MODEL=gemini-2.5-flash
# Max LLM extraction calls per aggregator run (cost guard). Default 40 if unset.
MAX_LLM_CALLS_PER_RUN=40

# ---- Admin allowlist (comma-separated emails allowed into /admin) ----
# Server-only: the "Admin" nav link is gated by a server probe, never by a
# client-readable copy of this list, so there is no NEXT_PUBLIC_ variant.
ADMIN_EMAILS=

# ---- Submission anti-spam (Cloudflare Turnstile) ----
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ---- IP pseudonymization salt (REQUIRED in production) ----
# Salts the sha256 hash of each submitter's IP so stored hashes are not
# reversible via a precomputed table. Must be a random 32+ byte secret, e.g.:
#   openssl rand -hex 32
# In production the submit endpoint throws if this is unset (no insecure
# default). Locally a non-secret dev placeholder is used when blank.
IP_HASH_SALT=

# ---- Maintainer notification email (Gmail SMTP) ----
# Sends a "new submission" email to ADMIN_EMAILS. If either is unset the mailer
# is a silent no-op (logs a warning). GMAIL_APP_PASSWORD is a Gmail app password
# (requires 2FA on the Google account), NOT the normal account password.
GMAIL_USER=
GMAIL_APP_PASSWORD=
